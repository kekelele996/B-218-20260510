<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.petadoption.mapper.PetMapper">

    <resultMap id="PetResultMap" type="com.petadoption.entity.Pet">
        <id property="id" column="id"/>
        <result property="name" column="name"/>
        <result property="type" column="type"/>
        <result property="breed" column="breed"/>
        <result property="age" column="age"/>
        <result property="gender" column="gender"/>
        <result property="size" column="size"/>
        <result property="color" column="color"/>
        <result property="weight" column="weight"/>
        <result property="vaccinated" column="vaccinated"/>
        <result property="neutered" column="neutered"/>
        <result property="healthDesc" column="health_desc"/>
        <result property="personality" column="personality"/>
        <result property="requirement" column="requirement"/>
        <result property="images" column="images"/>
        <result property="status" column="status"/>
        <result property="createTime" column="create_time"/>
        <result property="updateTime" column="update_time"/>
    </resultMap>

    <sql id="queryCondition">
        <where>
            <if test="query.status != null">
                AND status = #{query.status}
            </if>
            <if test="query.type != null and query.type != ''">
                AND type = #{query.type}
            </if>
            <if test="query.breed != null and query.breed != ''">
                AND breed = #{query.breed}
            </if>
            <if test="query.gender != null and query.gender != ''">
                AND gender = #{query.gender}
            </if>
            <if test="query.size != null and query.size != ''">
                AND size = #{query.size}
            </if>
            <if test="query.ageRange != null and query.ageRange != ''">
                <choose>
                    <when test="query.ageRange == 'young'">
                        AND age &lt;= 12
                    </when>
                    <when test="query.ageRange == 'adult'">
                        AND age &gt; 12 AND age &lt;= 84
                    </when>
                    <when test="query.ageRange == 'senior'">
                        AND age &gt; 84
                    </when>
                </choose>
            </if>
        </where>
    </sql>

    <select id="selectList" resultMap="PetResultMap">
        SELECT * FROM pet
        <include refid="queryCondition"/>
        <choose>
            <when test="query.sortBy == 'age_asc'">
                ORDER BY age ASC
            </when>
            <otherwise>
                ORDER BY create_time DESC
            </otherwise>
        </choose>
        LIMIT #{offset}, #{query.pageSize}
    </select>

    <select id="selectCount" resultType="long">
        SELECT COUNT(1) FROM pet
        <include refid="queryCondition"/>
    </select>

    <select id="selectById" resultMap="PetResultMap">
        SELECT * FROM pet WHERE id = #{id}
    </select>

    <update id="updateStatus">
        UPDATE pet SET status = #{status}, update_time = NOW() WHERE id = #{id}
    </update>

</mapper>
